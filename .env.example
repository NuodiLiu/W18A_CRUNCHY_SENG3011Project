# ──────────────────────────────────────
# Runtime mode (api | worker)
# ──────────────────────────────────────
APP_MODE=api
PORT=3000

# ──────────────────────────────────────
# AWS General
# ──────────────────────────────────────
AWS_REGION=ap-southeast-2
# For local dev only (LocalStack / DynamoDB Local)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ──────────────────────────────────────
# Endpoint overrides (local dev only)
# ──────────────────────────────────────
DYNAMODB_ENDPOINT=http://localhost:8000
S3_ENDPOINT=http://localhost:4566
SQS_ENDPOINT=http://localhost:4566

# ──────────────────────────────────────
# Resource names — <project> placeholder
# ──────────────────────────────────────
PROJECT_PREFIX=esgpipeline

SQS_QUEUE_NAME=esgpipeline-dev-import-jobs

DDB_JOBS_TABLE=esgpipeline-dev-jobs
DDB_STATE_TABLE=esgpipeline-dev-connector-state
DDB_IDEMPOTENCY_TABLE=esgpipeline-dev-idempotency

S3_CONFIG_BUCKET=esgpipeline-dev-config
S3_DATALAKE_BUCKET=esgpipeline-dev-datalake
