	"info": {
		"title": "esg-data-service",
		"version": "0.1.0",
		"description": "ESG CSV Ingestion, Retrieval & Preprocessing — single-container multi-domain API + SQS Worker",
		"contact": {}
	},
	"paths": {
		"/api/v1/preprocessing/jobs": {
			"post": {
				"operationId": "CreateJob",
				"responses": {
					"202": {
						"description": "Job accepted and enqueued",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/PreprocessJobAccepted"
								}
							}
						}
					},
					"400": {
						"description": "Validation error — missing required fields or unknown pipeline",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ErrorBody"
								}
							}
						}
					},
					"501": {
						"description": "Not yet implemented",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ErrorBody"
								}
							}
						}
					}
				},
				"description": "Submit an asynchronous preprocessing job.\nAccepts an S3 input URI and a pipeline name with optional parameters.\nReturns a job_id immediately for status polling.",
				"tags": [
					"Preprocessing"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/PreprocessJobRequest"
							}
						}
					}
				}
			}
		},
		"/api/v1/preprocessing/jobs/{jobId}": {
			"get": {
				"operationId": "GetJob",
				"responses": {
					"200": {
						"description": "Job status and result locations",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/PreprocessJobStatusResponse"
								}
							}
						}
					},
					"404": {
						"description": "Job not found",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ErrorBody"
								}
							}
						}
					},
					"501": {
						"description": "Not yet implemented",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ErrorBody"
								}
							}
						}
					}
				},
				"description": "Query the status and result locations of a submitted preprocessing job.\nReturns output_s3_uri, manifest_uri, and quality_report_uri on success,\nor an error message on failure.",
				"tags": [
					"Preprocessing"
				],
				"security": [],
				"parameters": [
					{
						"in": "path",
						"name": "jobId",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		},
		"/api/v1/preprocessing/pipelines": {
			"get": {
				"operationId": "GetPipelines",
				"responses": {
					"200": {
						"description": "List of available pipeline templates",
