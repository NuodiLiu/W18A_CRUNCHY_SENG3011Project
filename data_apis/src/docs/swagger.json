							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/PipelinesResponse"
								}
							}
						}
					},
					"501": {
						"description": "Not yet implemented",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ErrorBody"
