			"CreateImportResponse": {
				"properties": {
					"job_id": {
						"type": "string",
						"description": "UUID of the created import job."
					},
					"connection_id": {
						"type": "string",
						"description": "Deterministic SHA-256 hash identifying the connection (source config)."
					},
