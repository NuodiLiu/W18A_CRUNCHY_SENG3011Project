			"SourceSpecBody": {
				"properties": {
					"s3_uris": {
						"items": {
							"type": "string"
						},
						"type": "array",
						"description": "One or more S3 URIs pointing to the CSV files to import. Required if s3_prefix is not provided."
					},
					"s3_prefix": {
						"type": "string",
						"description": "S3 URI prefix to scan recursively for CSV files. Required if s3_uris is not provided."
					},
					"delimiter": {
						"type": "string",
						"description": "Column delimiter character. Defaults to comma."
					},
					"has_header": {
						"type": "boolean",
						"description": "Whether the CSV file has a header row. Defaults to true."
					},
					"timezone": {
						"type": "string",
						"description": "IANA timezone string for timestamps in the source file (e.g. \"UTC\", \"Australia/Sydney\")."
					},
					"time_column": {
						"type": "string",
						"description": "Name of the column to use as the event timestamp."
					}
				},
				"required": [
					"timezone"
				],
				"type": "object",
				"additionalProperties": true
			},
			"CreateImportBody": {
				"properties": {
					"connector_type": {
						"type": "string",
						"enum": [
							"esg_csv_batch"
						],
						"nullable": false,
						"description": "Must be \"esg_csv_batch\" for this connector."
					},
					"source_spec": {
						"$ref": "#/components/schemas/SourceSpecBody"
					},
					"mapping_profile": {
						"type": "string",
						"description": "Mapping profile name to apply during normalisation (e.g. \"esg_v1\")."
					},
					"data_source": {
						"type": "string",
						"description": "Human-readable data source label (e.g. \"Refinitiv\")."
					},
					"dataset_type": {
						"type": "string",
						"description": "Dataset type tag (e.g. \"ESG\")."
					},
					"ingestion_mode": {
						"type": "string",
						"enum": [
							"incremental",
							"full_refresh"
						],
						"description": "\"incremental\" only processes new/updated rows; \"full_refresh\" replaces the dataset."
					},
					"idempotency_key": {
						"type": "string",
						"description": "Optional idempotency key — re-submitting the same key returns the original job."
					}
				},
