							}
						}
					}
				},
				"description": "Returns the catalogue of built-in pipeline templates.\nEach entry includes a unique id, human-readable name, category, and\na JSON Schema describing its accepted params.",
				"tags": [
					"Preprocessing"
				],
				"security": [],
				"parameters": []
			}
		},
		"/health": {
			"get": {
				"operationId": "GetHealth",
				"responses": {
					"200": {
						"description": "Service is healthy",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/HealthResponse"
								}
							}
						}
					}
				},
				"description": "Returns service health status, version, and current server timestamp.\nIntended for load balancers, CI pipelines, and third-party monitoring.",
				"tags": [
					"Health"
				],
				"security": [],
				"parameters": []
			}
		},
		"/api/v1/events": {
			"get": {
				"operationId": "GetEvents",
				"responses": {
					"200": {
						"description": "List of ESG metric events",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/EventDatasetResponse"
								}
							}
						}
					},
					"501": {
						"description": "Not yet implemented",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ErrorBody"
								}
							}
						}
					}
				},
				"description": "Query normalized ESG metric events from the data lake.\nSupports filtering by company, metric name, ESG pillar, and year range.\nResults are paginated via limit/offset.",
				"tags": [
					"Events"
				],
				"security": [],
				"parameters": [
					{
						"in": "query",
						"name": "company_name",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "permid",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "metric_name",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "Environmental | Social | Governance",
						"in": "query",
						"name": "pillar",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "year_from",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"in": "query",
						"name": "year_to",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"in": "query",
						"name": "limit",
						"required": false,
						"schema": {
							"default": 50,
							"format": "double",
							"type": "number"
						}
					},
					{
						"in": "query",
						"name": "offset",
						"required": false,
						"schema": {
							"default": 0,
							"format": "double",
							"type": "number"
						}
					}
				]
			}
		},
