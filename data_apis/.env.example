# ──────────────────────────────────────
# Runtime mode (api | worker)
# ──────────────────────────────────────
APP_MODE=api
PORT=3000

# ──────────────────────────────────────
# AWS General
# ──────────────────────────────────────
AWS_REGION=ap-southeast-2
# For local dev only (LocalStack / DynamoDB Local)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ──────────────────────────────────────
# Endpoint overrides (local dev only)
# ──────────────────────────────────────
DYNAMODB_ENDPOINT=http://localhost:8000
S3_ENDPOINT=http://localhost:4566
SQS_ENDPOINT=http://localhost:4566

# ──────────────────────────────────────
# Resource names — <project> placeholder
# ──────────────────────────────────────
PROJECT_PREFIX=eia

SQS_QUEUE_NAME=eia-dev-import-jobs

DDB_JOBS_TABLE=eia-dev-jobs
DDB_STATE_TABLE=eia-dev-connector-state
DDB_IDEMPOTENCY_TABLE=eia-dev-idempotency

S3_CONFIG_BUCKET=eia-dev-config
S3_DATALAKE_BUCKET=eia-dev-datalake

# ──────────────────────────────────────
# PostgreSQL (docker-compose local dev)
# No password needed — docker-compose uses trust auth
# ──────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_DB=eia_dev
PG_CONNECTION_STRING=postgres://postgres@localhost:5432/eia_dev
